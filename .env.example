# ─── App ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ─── Supabase (required) ─────────────────────────────────────────────────────
# Project ref: zeyvvnviontbfnkhdhqm
NEXT_PUBLIC_SUPABASE_URL=https://zeyvvnviontbfnkhdhqm.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Optional server-only alias (same value as anon key)
SUPABASE_KEY=
# Server-only — guest orders, admin operations, Paystack fulfillment
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Auth redirect (Dashboard → Auth → URL Configuration):
# Site URL: https://YOUR_DOMAIN (or http://localhost:3000 locally)
# Redirect URLs: https://YOUR_DOMAIN/api/auth/callback

# ─── Paystack (required for card / MoMo / bank checkout) ─────────────────────
# Get keys: https://dashboard.paystack.com → Settings → API Keys & Webhooks
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_public_key
PAYSTACK_SECRET_KEY=sk_test_your_secret_key
# Webhook URL (production): https://YOUR_DOMAIN/api/payment/paystack/webhook
# Enable event: charge.success

# ─── BMS SMS / mNotify (required for order SMS) ──────────────────────────────
# Get keys: https://apps.mnotify.net or https://bms.africa
BMS_SMS_API_KEY=your_mnotify_api_key
BMS_SMS_SENDER_ID=GlossGirlie
BMS_SMS_ENABLED=true
# Optional: default https://api.mnotify.com/api
# BMS_SMS_API_BASE_URL=
# Admin SMS alert on new orders (Ghana: 233XXXXXXXXX)
ADMIN_PHONE=233XXXXXXXXX

# ─── Vercel deployment ───────────────────────────────────────────────────────
# Set all variables above in Vercel → Project → Settings → Environment Variables
# See DEPLOY_VERCEL.md for the full checklist

# ─── Email notifications (optional) ──────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# ─── Security ────────────────────────────────────────────────────────────────
JWT_SECRET=
# Optional: dedicated secret for hashing registration SMS OTP codes
# OTP_HASH_SECRET=
